# No environment variables required.
#
# This app uses OAuth 2.1 PKCE to authenticate with Monarch Money.
# On first run, visit http://localhost:3000 and click "Connect with Monarch"
# to complete the authorization flow. Tokens are stored in the local SQLite DB.
#
# Optional: override the app base URL (defaults to http://localhost:3000)
# APP_URL=http://localhost:3000
